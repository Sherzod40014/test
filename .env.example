# ---- App ----
NODE_ENV=development
APP_BASE_URL=http://localhost:3000
API_PORT=3000

# ---- Database (Postgres via Docker Compose) ----
DATABASE_URL=postgresql://erp:erp_dev_password@localhost:5432/erp_wms?schema=public

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- RabbitMQ ----
RABBITMQ_URL=amqp://erp:erp_dev_password@localhost:5672

# ---- MinIO (S3-compatible object storage for photos/videos/documents) ----
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=erp_minio_admin
MINIO_SECRET_KEY=erp_minio_dev_password
MINIO_BUCKET_MEDIA=cargo-media
MINIO_BUCKET_DOCUMENTS=documents
MINIO_BUCKET_LABELS=labels

# ---- Auth (guards land in M1) ----
JWT_SECRET=change_me_dev_only_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ---- Telegram notifications (wired in M8) ----
TELEGRAM_BOT_TOKEN=

# ---- AI product-name translation, Claude API (wired in M8) ----
ANTHROPIC_API_KEY=
