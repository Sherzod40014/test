{
  "compilerOptions": {
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@erp/shared-types": ["libs/shared/types/src/index.ts"],
      "@erp/shared-types/*": ["libs/shared/types/src/*"],
      "@erp/shared-dto": ["libs/shared/dto/src/index.ts"],
      "@erp/shared-dto/*": ["libs/shared/dto/src/*"],
      "@erp/shared-i18n": ["libs/shared/i18n/src/index.ts"],
      "@erp/shared-i18n/*": ["libs/shared/i18n/src/*"],
      "@erp/shared-ui-kit": ["libs/shared/ui-kit/src/index.ts"],
      "@erp/shared-ui-kit/*": ["libs/shared/ui-kit/src/*"],
      "@erp/shared-utils": ["libs/shared/utils/src/index.ts"],
      "@erp/shared-utils/*": ["libs/shared/utils/src/*"],
      "@erp/shared-config": ["libs/shared/config/src/index.ts"],
      "@erp/shared-config/*": ["libs/shared/config/src/*"],
      "@erp/backend-database": ["libs/backend/database/src/index.ts"],
      "@erp/backend-database/*": ["libs/backend/database/src/*"]
    }
  }
}
